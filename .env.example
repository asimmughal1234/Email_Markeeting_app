# Optional fallback Gmail / SMTP settings
# The app now supports sender Gmail fields in the frontend.
# If users enter sender Gmail/App Password in the UI, those values are used for that request.
# These environment variables are fallback values only.

GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
EMAIL_SENDER_NAME=Email Marketing Automation

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Optional defaults
DEFAULT_REPLY_TO=
MAX_ATTACHMENT_MB=10
